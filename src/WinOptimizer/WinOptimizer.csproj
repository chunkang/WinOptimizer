<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>WinOptimizer</AssemblyName>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <RootNamespace>WinOptimizer</RootNamespace>
    <Description>Windows system optimizer - detect banking software and optimize system settings</Description>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <!-- Version from git tag: vMajor.Minor.0 tag + commit count as patch -->
  <Target Name="SetGitVersion" BeforeTargets="PrepareForBuild;GenerateAssemblyInfo;GetAssemblyVersion">
    <Exec Command="git describe --tags --long --match &quot;v[0-9]*&quot; 2>&amp;1"
          ConsoleToMsBuild="true" StandardOutputImportance="low" IgnoreExitCode="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitDescribe" />
    </Exec>
    <PropertyGroup>
      <GitDescribe Condition="!$(GitDescribe.StartsWith('v'))">v0.1.0-0-g0000000</GitDescribe>
      <!-- Parse v0.1.0-3-gabcdef into Major.Minor=0.1 Commits=3 -->
      <GitTag>$([System.Text.RegularExpressions.Regex]::Match($(GitDescribe), 'v(\d+\.\d+)\.\d+-(\d+)-g[0-9a-f]+').Groups[1].Value)</GitTag>
      <GitCommits>$([System.Text.RegularExpressions.Regex]::Match($(GitDescribe), 'v\d+\.\d+\.\d+-(\d+)-g[0-9a-f]+').Groups[1].Value)</GitCommits>
      <GitHash>$([System.Text.RegularExpressions.Regex]::Match($(GitDescribe), 'g([0-9a-f]+)').Groups[1].Value)</GitHash>
      <Version Condition="'$(GitTag)' != ''">$(GitTag).$(GitCommits)</Version>
      <Version Condition="'$(GitTag)' == ''">0.1.0</Version>
      <BuildNumber Condition="'$(BuildNumber)' == ''">0</BuildNumber>
      <AssemblyVersion>$(Version).$(BuildNumber)</AssemblyVersion>
      <FileVersion>$(Version).$(BuildNumber)</FileVersion>
      <InformationalVersion>$(Version)+build.$(BuildNumber)</InformationalVersion>
    </PropertyGroup>
    <Message Importance="high" Text="Git version: $(Version) (from $(GitDescribe))" />
  </Target>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>

</Project>
